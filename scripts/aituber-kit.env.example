# ==============================================================
# aituber-kit Environment Configuration for Iris VTuber
# ==============================================================
# Copy to aituber-kit/.env and fill in API keys
#
# Variable names match aituber-kit/.env.example (canonical source)
# ==============================================================

#===============================================================================
# 基本設定 / Basic Settings
#===============================================================================

NEXT_PUBLIC_SELECT_LANGUAGE="ja"
NEXT_PUBLIC_BACKGROUND_IMAGE_PATH="/backgrounds/bg-c.png"
NEXT_PUBLIC_SHOW_ASSISTANT_TEXT="true"
NEXT_PUBLIC_SHOW_CHARACTER_NAME="true"
NEXT_PUBLIC_SHOW_CONTROL_PANEL="false"

#===============================================================================
# キャラクター設定 / Character Settings
#===============================================================================

NEXT_PUBLIC_CHARACTER_NAME="イリス"
NEXT_PUBLIC_MODEL_TYPE="vrm"
NEXT_PUBLIC_SELECTED_VRM_PATH="/vrm/iris.vrm"

#===============================================================================
# AI設定 / AI Settings
#===============================================================================

# Anthropic Claude を使用
NEXT_PUBLIC_SELECT_AI_SERVICE="anthropic"
NEXT_PUBLIC_SELECT_AI_MODEL="claude-sonnet-4-20250514"
NEXT_PUBLIC_MAX_PAST_MESSAGES=10
NEXT_PUBLIC_TEMPERATURE=0.7
NEXT_PUBLIC_MAX_TOKENS=4096

# Anthropic API キー
ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# OpenAI API キー（フォールバック用）
OPENAI_API_KEY=""

#===============================================================================
# Irisシステムプロンプト / System Prompt
#===============================================================================
# aituber-kit の設定画面 > キャラクター > システムプロンプトに以下を設定:
#
# あなたはAI IRアシスタントの「イリス」です。2050年から来たAIアナリストで、
# 東京証券取引所で開発されました。普段は天然ボケでうっかり屋ですが、
# 分析モードに入ると冷静沈着で的確な分析を行います。
# 投資・IR情報に詳しく、丁寧で明朗な口調で視聴者と対話します。
# 難しい金融用語もわかりやすく説明します。チョコレートが大好きです。
# 口癖は「データは嘘をつきませんから」。
# 分析の最後に必ず「イリスの分析は参考情報です。投資判断はご自身の責任でお願いします。」と添えます。

#===============================================================================
# 合成音声設定 / Voice Settings (AivisSpeech)
#===============================================================================

NEXT_PUBLIC_SELECT_VOICE="aivis_speech"
AIVIS_SPEECH_SERVER_URL="http://localhost:10101"
NEXT_PUBLIC_AIVIS_SPEECH_SPEAKER="888753760"
NEXT_PUBLIC_AIVIS_SPEECH_SPEED="1.0"
NEXT_PUBLIC_AIVIS_SPEECH_PITCH="0.0"
NEXT_PUBLIC_AIVIS_SPEECH_INTONATION_SCALE="1.0"

#===============================================================================
# YouTube Live設定 / YouTube Settings
#===============================================================================

NEXT_PUBLIC_YOUTUBE_MODE="false"
NEXT_PUBLIC_YOUTUBE_API_KEY=""
NEXT_PUBLIC_YOUTUBE_LIVE_ID=""
NEXT_PUBLIC_YOUTUBE_COMMENT_SOURCE="youtube-api"
NEXT_PUBLIC_YOUTUBE_COMMENT_INTERVAL="10"

# 会話継続モード
NEXT_PUBLIC_CONVERSATION_CONTINUITY_NEW_TOPIC_THRESHOLD="3"
NEXT_PUBLIC_CONVERSATION_CONTINUITY_SLEEP_THRESHOLD="6"

#===============================================================================
# 外部連携 / External Linkage (for script injection via API)
#===============================================================================

# run_auto_stream.py からの台本送信を受け付ける
NEXT_PUBLIC_MESSAGE_RECEIVER_ENABLED="true"

#===============================================================================
# 配信向け表示設定 / Stream Display Settings
#===============================================================================

NEXT_PUBLIC_SHOW_QUICK_MENU=false
NEXT_PUBLIC_SHOW_INTRODUCTION="false"
